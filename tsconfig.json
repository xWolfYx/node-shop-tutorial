{
	"compilerOptions": {
		"target": "ES2022",

		// ESM (Modules) for Node
		"module": "NodeNext",
		"moduleResolution": "NodeNext",

		// Project structure
		"rootDir": "./app/src",
		"outDir": "./dist",

		// Type safety
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,

		// Node environment types
		"types": ["node"],

		// Output behavior
		"sourceMap": true,
		"declaration": true,
		"declarationMap": true,

		// Modern module behavior (important for ESM)
		"verbatimModuleSyntax": true,
		"moduleDetection": "force",

		// Good defaults for backend projects
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,

		// Prevent accidental implicit any in some cases
		"noImplicitOverride": true,
		"noFallthroughCasesInSwitch": true
	},

	"include": ["app/src"],
	"exclude": ["node_modules", "dist"]
}
